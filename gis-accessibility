<script>
  /* Tab switching */
  function show(tab) {
    document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
    document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); b.setAttribute('aria-selected','false'); });
    document.getElementById(tab === 'handout' ? 'ho-panel' : 'cl-panel').classList.add('active');
    document.getElementById('btn-' + tab).classList.add('active');
    document.getElementById('btn-' + tab).setAttribute('aria-selected','true');
  }

  /* Checkbox persistence + progress */
  (function() {
    var STORAGE_KEY = 'gis-a11y-checklist';
    var boxes = document.querySelectorAll('#cl-panel .check-input');
    var total = boxes.length;

    function loadState() {
      try {
        var saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
        boxes.forEach(function(cb) {
          if (saved[cb.dataset.id]) cb.checked = true;
        });
      } catch(e) { /* silent */ }
    }

    function saveState() {
      var state = {};
      boxes.forEach(function(cb) {
        if (cb.checked) state[cb.dataset.id] = true;
      });
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) { /* silent */ }
    }

    function updateProgress() {
      var checked = document.querySelectorAll('#cl-panel .check-input:checked').length;
      var pct = Math.round((checked / total) * 100);
      document.getElementById('progress-text').textContent = checked + ' of ' + total + ' checked';
      document.getElementById('progress-pct').textContent = pct + '%';
      document.getElementById('progress-fill').style.width = pct + '%';
    }

    loadState();
    updateProgress();

    boxes.forEach(function(cb) {
      cb.addEventListener('change', function() {
        saveState();
        updateProgress();
      });
    });
  })();
</script>
